// SGE — Prisma schema
// Sprint 1: Auth (RF01) + Cadastros base (RF02)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

enum CourseStatus {
  ACTIVE
  ARCHIVED
}

enum SemesterPeriod {
  FIRST
  SECOND
}

enum AssessmentType {
  FREQUENCY
  TEST
  EXAM
  PROJECT
  HOMEWORK
}

enum RoundingRule {
  FLOOR
  CEIL
  ROUND
  NONE
}

enum AttendanceMethod {
  MANUAL
  QR
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  JUSTIFIED
  LATE
}

enum ClassSessionStatus {
  OPEN
  CLOSED
  CANCELLED
}

// ─────────────────────────────────────────────
// Identity & Auth
// ─────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  passwordHash  String
  role          UserRole   @default(STUDENT)
  status        UserStatus @default(PENDING)
  phone         String?
  externalCode  String?    @unique
  dateOfBirth   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // relations
  refreshTokens    RefreshToken[]
  passwordResets   PasswordResetToken[]
  coordinatorOf    Course[]
  teacherClasses   Class[]
  enrollments      Enrollment[]      @relation("EnrollmentOwner")
  reviewedEnrollments Enrollment[] @relation("EnrollmentReviewer")
  registrations    Registration[]
  gradesGiven      Grade[]           @relation("GradeTeacher")
  auditDocuments    AuditDocument[]
  payments         Payment[]

  @@index([role])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// Academic structure (RF02)
// ─────────────────────────────────────────────

model Course {
  id            String       @id @default(cuid())
  name          String
  code          String       @unique
  description   String?
  durationYears Int          @default(3)
  status        CourseStatus @default(ACTIVE)
  coordinatorId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  coordinator User?      @relation(fields: [coordinatorId], references: [id], onDelete: SetNull)
  disciplines Discipline[]
  selectionProcesses SelectionProcess[]

  @@index([coordinatorId])
  @@index([status])
  @@map("courses")
}

model Discipline {
  id          String   @id @default(cuid())
  courseId     String
  name        String
  code        String
  description String?
  credits     Int      @default(4)
  workloadHrs Int      @default(60)
  semester    Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  classes Class[]

  @@unique([courseId, code])
  @@index([courseId])
  @@index([semester])
  @@map("disciplines")
}

model Class {
  id           String         @id @default(cuid())
  disciplineId String
  teacherId    String?
  year         Int
  period       SemesterPeriod @default(FIRST)
  capacity     Int            @default(60)
  schedule     String?
  room         String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  discipline Discipline @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  teacher    User?       @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  registrations Registration[]
  assessmentPlan AssessmentPlan?
  sessions   ClassSession[]

  @@unique([disciplineId, year, period])
  @@index([disciplineId])
  @@index([teacherId])
  @@index([year, period])
  @@map("classes")
}

// ─────────────────────────────────────────────
// Enums — Inscrição & Matrícula (RF03)
// ─────────────────────────────────────────────

enum EnrollmentStatus {
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  WAITLIST
}

enum RegistrationStatus {
  ACTIVE
  CANCELLED
  COMPLETED
}

enum SelectionProcessStatus {
  DRAFT
  OPEN
  CLOSED
  CANCELLED
}

enum EnrollmentDocumentType {
  ID_DOCUMENT
  PAYMENT_PROOF
  TRANSCRIPT
  PHOTO
  OTHER
}

// ─────────────────────────────────────────────
// Inscrição & Matrícula (RF03)
// ─────────────────────────────────────────────

model SelectionProcess {
  id          String                 @id @default(cuid())
  courseId     String
  academicYear Int
  period       SemesterPeriod         @default(FIRST)
  title        String
  description  String?
  openDate     DateTime
  closeDate    DateTime
  vacancies    Int                    @default(0)
  status       SelectionProcessStatus @default(DRAFT)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]

  @@unique([courseId, academicYear, period])
  @@index([courseId])
  @@index([status])
  @@index([academicYear])
  @@map("selection_processes")
}

model Enrollment {
  id                  String                 @id @default(cuid())
  userId              String
  selectionProcessId String
  status              EnrollmentStatus       @default(SUBMITTED)
  reviewedById        String?
  reviewNote          String?
  reviewedAt         DateTime?
  rejectionReason    String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  user              User             @relation("EnrollmentOwner", fields: [userId], references: [id], onDelete: Cascade)
  selectionProcess  SelectionProcess @relation(fields: [selectionProcessId], references: [id], onDelete: Cascade)
  reviewedBy        User?            @relation("EnrollmentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  documents         EnrollmentDocument[]
  registration      Registration?

  @@unique([userId, selectionProcessId])
  @@index([userId])
  @@index([selectionProcessId])
  @@index([status])
  @@map("enrollments")
}

model EnrollmentDocument {
  id          String                @id @default(cuid())
  enrollmentId String
  type        EnrollmentDocumentType
  fileUrl     String
  fileName    String
  mimeType    String
  sizeBytes   Int
  uploadedAt  DateTime              @default(now())

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@map("enrollment_documents")
}

model Registration {
  id           String             @id @default(cuid())
  studentId    String
  classId      String
  academicYear Int
  enrollmentId String?            @unique
  status       RegistrationStatus @default(ACTIVE)
  enrolledAt   DateTime           @default(now())
  cancelledAt  DateTime?

  student   User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class     Class      @relation(fields: [classId], references: [id], onDelete: Cascade)
  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  grades      Grade[]
  attendances Attendance[]

  @@unique([studentId, classId, academicYear])
  @@index([studentId])
  @@index([classId])
  @@index([academicYear])
  @@map("registrations")
}

// ─────────────────────────────────────────────
// Avaliação & Notas (RF04)
// ─────────────────────────────────────────────

model AssessmentPlan {
  id             String        @id @default(cuid())
  classId        String        @unique
  scaleMax       Float         @default(20)
  passingScore   Float         @default(10)
  minAttendancePct Float       @default(70)
  roundingRule   RoundingRule  @default(ROUND)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  class  Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  items  AssessmentItem[]

  @@map("assessment_plans")
}

model AssessmentItem {
  id              String         @id @default(cuid())
  planId          String
  type            AssessmentType
  name            String
  weight          Float           @default(0)
  maxScore        Float           @default(20)
  order           Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  plan   AssessmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  grades Grade[]

  @@index([planId])
  @@index([order])
  @@map("assessment_items")
}

model Grade {
  id              String   @id @default(cuid())
  registrationId  String
  assessmentItemId String
  score           Float
  note            String?
  recordedById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  registration  Registration   @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  assessmentItem AssessmentItem @relation(fields: [assessmentItemId], references: [id], onDelete: Cascade)
  recordedBy     User           @relation("GradeTeacher", fields: [recordedById], references: [id], onDelete: SetNull)

  @@unique([registrationId, assessmentItemId])
  @@index([registrationId])
  @@index([assessmentItemId])
  @@map("grades")
}

// ─────────────────────────────────────────────
// Presença & Sessões (RF05)
// ─────────────────────────────────────────────

model ClassSession {
  id        String            @id @default(cuid())
  classId   String
  date      DateTime          @default(now())
  qrToken   String?           @unique
  qrExpiresAt DateTime?
  status    ClassSessionStatus @default(OPEN)
  closedAt  DateTime?
  createdAt DateTime          @default(now())

  class       Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  attendances Attendance[]

  @@index([classId])
  @@index([date])
  @@map("class_sessions")
}

model Attendance {
  id             String           @id @default(cuid())
  registrationId String
  classSessionId String
  status         AttendanceStatus @default(ABSENT)
  method         AttendanceMethod @default(MANUAL)
  markedAt       DateTime         @default(now())

  registration  Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  classSession  ClassSession  @relation(fields: [classSessionId], references: [id], onDelete: Cascade)

  @@unique([registrationId, classSessionId])
  @@index([registrationId])
  @@index([classSessionId])
  @@map("attendances")
}

// ─────────────────────────────────────────────
// Forward-declared models (Sprint 4+); minimal fields now
// ─────────────────────────────────────────────

model AuditDocument {
  id        String   @id @default(cuid())
  ownerId   String
  type      String
  fileUrl   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  user User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@map("audit_documents")
}

model Payment {
  id         String   @id @default(cuid())
  userId     String
  reference  String?
  amount     Decimal  @db.Decimal(12, 2)
  concept    String
  status     String   @default("PENDING")
  gateway    String   @default("MULTICAIXA_MOCK")
  rawResponse Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("payments")
}
