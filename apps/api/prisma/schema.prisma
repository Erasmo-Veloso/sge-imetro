// SGE — Prisma schema
// Sprint 1: Auth (RF01) + Cadastros base (RF02)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  SUSPENDED
}

enum CourseStatus {
  ACTIVE
  ARCHIVED
}

enum SemesterPeriod {
  FIRST
  SECOND
}

// ─────────────────────────────────────────────
// Identity & Auth
// ─────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  passwordHash  String
  role          UserRole   @default(STUDENT)
  status        UserStatus @default(PENDING)
  phone         String?
  externalCode  String?    @unique
  dateOfBirth   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // relations
  refreshTokens    RefreshToken[]
  passwordResets   PasswordResetToken[]
  coordinatorOf    Course[]
  teacherClasses   Class[]
  enrollments      Enrollment[]
  registrations    Registration[]
  auditDocuments    AuditDocument[]
  payments         Payment[]

  @@index([role])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// Academic structure (RF02)
// ─────────────────────────────────────────────

model Course {
  id            String       @id @default(cuid())
  name          String
  code          String       @unique
  description   String?
  durationYears Int          @default(3)
  status        CourseStatus @default(ACTIVE)
  coordinatorId String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  coordinator User?      @relation(fields: [coordinatorId], references: [id], onDelete: SetNull)
  disciplines Discipline[]

  @@index([coordinatorId])
  @@index([status])
  @@map("courses")
}

model Discipline {
  id          String   @id @default(cuid())
  courseId     String
  name        String
  code        String
  description String?
  credits     Int      @default(4)
  workloadHrs Int      @default(60)
  semester    Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  classes Class[]

  @@unique([courseId, code])
  @@index([courseId])
  @@index([semester])
  @@map("disciplines")
}

model Class {
  id           String         @id @default(cuid())
  disciplineId String
  teacherId    String?
  year         Int
  period       SemesterPeriod @default(FIRST)
  capacity     Int            @default(60)
  schedule     String?
  room         String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  discipline Discipline @relation(fields: [disciplineId], references: [id], onDelete: Cascade)
  teacher    User?       @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  @@unique([disciplineId, year, period])
  @@index([disciplineId])
  @@index([teacherId])
  @@index([year, period])
  @@map("classes")
}

// ─────────────────────────────────────────────
// Forward-declared models (Sprint 2+); minimal fields now
// ─────────────────────────────────────────────

model Enrollment {
  id     String @id @default(cuid())
  userId String
  // selectionProcessId String (Sprint 2)
  status String @default("SUBMITTED")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("enrollments")
}

model Registration {
  id      String @id @default(cuid())
  studentId String
  classId String?
  status  String @default("ACTIVE")
  academicYear Int
  createdAt DateTime @default(now())

  user User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("registrations")
}

model AuditDocument {
  id        String   @id @default(cuid())
  ownerId   String
  type      String
  fileUrl   String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  user User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@map("audit_documents")
}

model Payment {
  id        String   @id @default(cuid())
  userId    String
  reference String?
  amount    Decimal  @db.Decimal(12, 2)
  concept   String
  status    String   @default("PENDING")
  gateway   String   @default("MULTICAIXA_MOCK")
  rawResponse Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("payments")
}
