# --- Application ---
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:5173
WEB_URL=http://localhost:5173

# --- Database (Neon Postgres) ---
# Replace with your Neon connection string
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# --- Auth (JWT) ---
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace_with_64_byte_secret_min_32_chars_xxxxxxxxxxxx
JWT_REFRESH_SECRET=replace_with_64_byte_secret_min_32_chars_xxxxxxxxxxxx
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# --- Storage ---
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage

# --- Mail (Resend) ---
# Leave empty in dev to skip real sends (console sink)
RESEND_API_KEY=
MAIL_FROM=no-reply@sge.local

# --- QR Attendance ---
QR_TOKEN_TTL_SECONDS=600
